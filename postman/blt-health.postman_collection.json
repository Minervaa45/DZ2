{
  "info": {
    "name": "BLT Health Users CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://{{baseUrl}}/users",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"User {{$timestamp}}\",\n  \"email\": \"user{{$timestamp}}@example.com\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const createdUser = pm.response.json();",
              "pm.collectionVariables.set('userId', createdUser.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get user",
      "request": {
        "method": "GET",
        "url": "http://{{baseUrl}}/users/{{userId}}"
      }
    },
    {
      "name": "Update user",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://{{baseUrl}}/users/{{userId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ada Byron\"\n}"
        }
      }
    },
    {
      "name": "Delete user",
      "request": {
        "method": "DELETE",
        "url": "http://{{baseUrl}}/users/{{userId}}"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "arch.homework"
    },
    {
      "key": "userId",
      "value": ""
    }
  ]
}
